# CrucibAI — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# The canonical .env.example with all documented variables lives in:
#       backend/.env.example
#
# To configure locally:
#   1. Copy:  cp backend/.env.example backend/.env
#   2. Edit:  Fill in DATABASE_URL, JWT_SECRET, and LLM API keys
#   3. Run:   cd backend && uvicorn server:app --reload
#
# This file is kept as a convenience so developers find it from the repo root.
# Do NOT edit this file — edit backend/.env.example instead.
#
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# RAILWAY DEPLOYMENT — Required Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Set these in Railway → Service → Variables.  The app will NOT start without
# DATABASE_URL and JWT_SECRET.  LLM keys are required for AI chat to work.
#
# REQUIRED (app crashes without these):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/crucibai
JWT_SECRET=change-me-to-a-long-random-string
#
# REQUIRED FOR AI CHAT (chat returns error without at least one):
ANTHROPIC_API_KEY=
CEREBRAS_API_KEY=
OPENAI_API_KEY=
#
# REQUIRED FOR BENCHMARK ENDPOINT:
CRUCIBAI_BENCHMARK_SECRET=
#
# STRONGLY RECOMMENDED (OAuth login, web search, billing):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TAVILY_API_KEY=
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=
#
# URL CONFIGURATION (set these in Railway to match your domain):
FRONTEND_URL=
BACKEND_PUBLIC_URL=
# ═══════════════════════════════════════════════════════════════════════════════

# Local dev URLs:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000

# For ALL options, see: backend/.env.example
