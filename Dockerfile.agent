# Dockerfile.agent
# Multi-stage build for minimal attack surface
# Security-hardened agent sandbox

# Stage 1: Builder
FROM node:18-alpine AS builder

WORKDIR /build

# Copy package files
COPY package*.json ./

# Install production dependencies
RUN npm ci --only=production

# Copy source code
COPY . .

# Stage 2: Runtime (minimal)
FROM node:18-alpine

# Install only necessary runtime dependencies
RUN apk add --no-cache \
    python3=~3.11 \
    git=~2.40 \
    curl=~8.0 \
    ca-certificates

# Create non-root user with minimal privileges
RUN addgroup -g 1000 crucibai && \
    adduser -D -u 1000 -G crucibai crucibai

# Set working directory
WORKDIR /app

# Copy dependencies and source from builder
COPY --chown=crucibai:crucibai --from=builder /build/node_modules ./node_modules
COPY --chown=crucibai:crucibai --from=builder /build/package*.json ./
COPY --chown=crucibai:crucibai . .

# Security: Make system directories read-only
RUN chmod -R a-w /etc /sys /proc/sys && \
    chmod -R a-w /usr/local/etc && \
    chmod -R a-w /etc/apt

# Drop unnecessary Linux capabilities
RUN setcap -r /bin/sh 2>/dev/null || true

# Create tmp and home with proper permissions
RUN mkdir -p /tmp /home/crucibai && \
    chown -R crucibai:crucibai /tmp /home/crucibai && \
    chmod 700 /tmp /home/crucibai

# Switch to non-root user
USER crucibai:crucibai

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD node -e "process.exit(0)"

# Metadata
LABEL org.opencontainers.image.title="CrucibAI Agent Sandbox" \
      org.opencontainers.image.description="Hardened sandbox for agent execution" \
      org.opencontainers.image.version="1.0.0" \
      org.opencontainers.image.vendor="CrucibAI"

# Immutable entrypoint
ENTRYPOINT ["node"]
CMD ["executor.js"]
