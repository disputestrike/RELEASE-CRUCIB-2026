# CrucibAI Backend — copy to `.env` in this folder (`backend/.env`). Never commit `.env`.
# `load_dotenv` loads `backend/.env` automatically when you run uvicorn from `backend/`.

# Local dev: set CRUCIBAI_DEV=1 (also set by ../run-dev.ps1) for relaxed CSRF / rate limits.
# Health probes: GET /api/health/live (liveness), /api/health/ready (readiness, requires DATABASE_URL). Plain /api/health is cheap; ?deps=true or HEALTH_CHECK_DEPS=1 runs the DB probe and returns 503 if the DB is missing or down.
# With CRUCIBAI_DEV=1 and no LLM keys below, Workspace returns a small stub app so preview still runs.
# CRUCIBAI_DEV=1 also skips extended Auto-Runner preflight (Node/npm on PATH + health ping) so "Approve & Run" works on Windows when the API process does not see Node.
# Optional: CRUCIBAI_SKIP_AUTORUNNER_PREFLIGHT=1 without CRUCIBAI_DEV (not recommended for production).
# If you run without CRUCIBAI_DEV but Node is not on the API PATH: CRUCIBAI_SKIP_NODE_VERIFY=1 skips `node --check` in verification.compile (run-dev.ps1 sets this).
# Auto-Runner plan checklist is advisory by default. Set CRUCIBAI_STRICT_PLAN_BLOCKERS=1 to allow hard-blocking missing inputs (rare).
#
# Spec Guardian (goal vs runner capability): advisory | strict | off
# - advisory (default): records violations + compliance %; run-auto still proceeds (UI warnings are non-blocking)
# - strict: blocks run-auto when goal demands unsupported stacks (Next on vite target, TS Node API, ORM, etc.)
# Production hard gate: CRUCIBAI_SPEC_GUARD_MODE=strict
# CRUCIBAI_SPEC_GUARD_MODE=strict
#
# Completion enforcement gate: controls whether critical feature checks hard-block delivery.
# strict (default + REQUIRED in production): blocks job completion if proof is missing/advisory
# advisory: records violations but allows delivery (dev only — DO NOT use in production)
# off: disables enforcement entirely (never use in production)
# CRUCIBAI_ENFORCEMENT_GATE=strict
CRUCIBAI_ENFORCEMENT_GATE=strict
#
# BIV repair attempts: how many targeted DAG retries BIV can trigger on failure (0–2)
# CRUCIBAI_BIV_REPAIR_ATTEMPTS=1
#
# deploy.build: when multitenant RLS migration exists, require backend/*.py to mention set_config + app.tenant_id (set 0 to disable)
# CRUCIBAI_TENANT_CONTEXT_DEPLOY_GATE=1
#
# Optional: live RBAC smoke against running API (anonymous / user token admin denial)
# CRUCIBAI_RBAC_SMOKE_URL=http://127.0.0.1:8000
# CRUCIBAI_RBAC_USER_TOKEN=
#
# verification.security runs tenancy_smoke + stripe_replay + rbac (behavior bundle). In CI (GITHUB_ACTIONS), if
# db/migrations has multitenant RLS, PostgreSQL DATABASE_URL is required for live tenancy proof.
# CRUCIBAI_BEHAVIOR_TENANCY_STRICT=1
#
# After a failed verify_step, executor may run deterministic fix + re-verify (0–5 attempts)
# CRUCIBAI_INNER_VERIFY_REPAIR_MAX=2
#
# If set, git commit inside the job workspace after a deterministic verification repair (workspace must be a git repo)
# CRUCIBAI_VERIFICATION_AUTO_COMMIT=0
#
# JSON request log lines + trace/tenant context (see orchestration/observability.py)
# CRUCIBAI_STRUCTURED_LOGS=0
#
# OpenTelemetry tracer with console span export (optional; adds opentelemetry-* deps)
# CRUCIBAI_OTEL=0
#
# Skip crew-style planning sketches (docs/CREW_*.md, db/migrations/000_crew_schema.sql)
# CRUCIBAI_DISABLE_CREW=0
#
# Set to 1 in production-style environments to forbid stubbed crew Agent.execute and dev_stub_llm chat stubs (must wire real LLM).
# CRUCIBAI_REAL_AGENT_ONLY=0
#
# Workspace assembly V2 (multi-file File Tool + swarm): **on by default**. Set 0 / false / no / off for legacy four-file writer.
# CRUCIBAI_ASSEMBLY_V2=0
#
# Generation policy (minimal coherent workspaces):
# - CRUCIBAI_LEGACY_BROAD_AGENT_SUPPORT=1 restores old “default support” agent pack on intelligent selection runs.
# - CRUCIBAI_WORKSPACE_SCAFFOLD_MODE=full pre-creates legacy empty dirs (client/server/docs/...); default is minimal (META only).
#
# CRUCIBAI_LEGACY_BROAD_AGENT_SUPPORT=0
# CRUCIBAI_WORKSPACE_SCAFFOLD_MODE=minimal
#
# Content policy (optional): block oversized prompts always; with STRICT, also block substrings (comma-separated, case-insensitive).
# CRUCIBAI_MAX_USER_PROMPT_CHARS=200000
# CRUCIBAI_CONTENT_POLICY_STRICT=0
# CRUCIBAI_CONTENT_BLOCK_SUBSTRINGS=
#
# JWT: rotating JWT_SECRET invalidates all access tokens (session hygiene). Prefer short-lived access + refresh in production (app-specific).
#
# Rate limits (production; skipped when CRUCIBAI_DEV=1): per-IP + per-user (JWT user_id) buckets.
# RATE_LIMIT_PER_MINUTE=100
# RATE_LIMIT_PER_IP_PER_MINUTE=300
#
# Credit balance audit lines (log aggregation / drift): one structured line per deduction
# CRUCIBAI_CREDIT_BALANCE_LOG=0
#
# CreditTracker.record_usage(..., idempotency_key=...) — same user+key dedupes deduction (retries / double-submit); see credit_tracker.py
# HTTP: **Idempotency-Key** (or **X-Idempotency-Key**) on **POST /api/ai/chat** and **/api/ai/chat/stream** is forwarded to usage recording (CORS allows these headers).
#
# Sandbox subprocess rlimits (Linux API host only; child preexec). Wall-clock timeout is the `execute(timeout=...)` arg.
# CRUCIBAI_SANDBOX_MAX_MEMORY_MB=512
# CRUCIBAI_SANDBOX_CPU_SECONDS=30
# CRUCIBAI_SANDBOX_MAX_NPROC=10
# CRUCIBAI_SANDBOX_MAX_FSIZE_MB=50
#
# deploy.build verification: set to 1 to FAIL if workspace code files match leaked-credential patterns
# CRUCIBAI_PRODUCTION_GATE_STRICT=0
#
# Optional: verification.api_smoke performs a live HTTP GET when set (e.g. while API runs on another port)
# CRUCIBAI_API_SMOKE_URL=http://127.0.0.1:8000/health
#
# CI: GitHub Actions sets GITHUB_ACTIONS=true so pytest skips `docker compose` and uses service-container DATABASE_URL.
# Post-deploy probe (repo root): deploy/healthcheck.sh https://your-api.example.com
#
# Optional: verification.security runs `npm audit --omit=dev --json` when npm is on PATH (can be slow)
# CRUCIBAI_NPM_AUDIT_ON_SECURITY=0
# With audit on: fail verification.security when npm audit exits non-zero
# CRUCIBAI_NPM_AUDIT_STRICT=0

# --- Optional: UI-only local smoke (no Postgres) ---
# Leave DATABASE_URL unset and set CRUCIBAI_DEV=1: /api/health + in-memory guest (services/dev_guest.py)
# so the SPA can load /app/workspace. Orchestrator/jobs still need real DATABASE_URL (see docker-compose.yml port 5434).

# --- Required for full local runs ---
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/crucibai
JWT_SECRET=change-me-to-a-long-random-string

# --- LLM (set at least one) ---
ANTHROPIC_API_KEY=
CEREBRAS_API_KEY=
# Optional pool (round-robin): CEREBRAS_API_KEY_1 … CEREBRAS_API_KEY_5
# CEREBRAS_API_KEY_1=
# CEREBRAS_API_KEY_2=

# Voice / Whisper (Landing, Dashboard, Workspace)
OPENAI_API_KEY=

# Web search
TAVILY_API_KEY=

# --- Local URLs (override any production FRONTEND_URL / API_BASE_URL in your shell) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Workspace API key encryption at rest (Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ---
# CRUCIBAI_ENCRYPTION_KEY=

# --- Queue (optional; omit for in-memory queue) ---
# REDIS_URL=redis://127.0.0.1:6379/0

# --- Pool tuning ---
# DB_POOL_MIN_SIZE=5
# DB_POOL_MAX_SIZE=20
# DB_POOL_TIMEOUT=30

# --- Optional tuning (used where referenced in code / agents) ---
# API_TIMEOUT=120
# BUILD_TIMEOUT_SECONDS=3600
# WORKERS=4
# PARALLEL_WORKERS=4
# MAX_CONCURRENT_AGENTS=50

# Braintree billing (Starlight LLC: Crucible AI, RevTree, Gulfshire, and other product lines)
# BRAINTREE_ENVIRONMENT=sandbox
# BRAINTREE_MERCHANT_ID=
# BRAINTREE_PUBLIC_KEY=
# BRAINTREE_PRIVATE_KEY=
# BRAINTREE_MERCHANT_ACCOUNT_ID=
# APP_URL=https://your-production-domain.com
# Webhook URL in Braintree: ${APP_URL}/api/webhooks/braintree
# Optional recurring-plan seed values; database prices remain the source of truth.
# BRAINTREE_PLAN_BUILDER_MONTHLY=
# BRAINTREE_PLAN_PRO_MONTHLY=
# BRAINTREE_PLAN_SCALE_MONTHLY=
# BRAINTREE_PLAN_TEAMS_MONTHLY=
# BRAINTREE_PLAN_BUILDER_YEARLY=
# BRAINTREE_PLAN_PRO_YEARLY=
# BRAINTREE_PLAN_SCALE_YEARLY=
# BRAINTREE_PLAN_TEAMS_YEARLY=

# S3 / SMTP: see previous sections in your deploy template

# Repair loop v2 — iterative fix with scratchpad accumulation
FEATURE_REPAIR_V2=1
