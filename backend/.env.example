# CrucibAI Backend – copy to .env and fill in. Never commit .env or real keys.
# Railway/deploy: set variables in dashboard. Local: copy this file to .env and paste your values.

# Required: PostgreSQL (primary database)
DATABASE_URL=postgresql://user:password@localhost:5432/crucibai

# LLM: Anthropic (Claude) + Cerebras — set at least one for builds to work (e.g. in Railway Variables)
ANTHROPIC_API_KEY=
CEREBRAS_API_KEY=
# Voice (microphone): OpenAI Whisper — required for /voice/transcribe (Landing, Dashboard, Workspace)
OPENAI_API_KEY=

# Required for auth
JWT_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=  # usually auto from request; set if needed

# CORS (comma-separated origins; * for dev)
CORS_ORIGINS=http://localhost:3000

# Web search for real-time questions (weather, news, etc.) – get key at https://tavily.com
# TAVILY_API_KEY=

# Images (optional): Together.ai – get key at https://www.together.ai
# TOGETHER_API_KEY=
# TOGETHER_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Videos (optional): Pexels – free key at https://www.pexels.com/api
# PEXELS_API_KEY=

# Branding + OAuth: public backend URL (used for OAuth redirect_uri so Google gets https in production).
# BACKEND_PUBLIC_URL=https://crucibai-production.up.railway.app
# CRUCIBAI_BRANDING_URL=https://api.crucibai.com/branding

# Stripe (for token purchases — set for full payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:3000

# Queue: Redis for multi-replica workers (omit = in-memory queue, still works)
# REDIS_URL=redis://localhost:6379/0

# Storage: S3 for uploads/exports (omit = local backend/uploads/)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=crucibai-uploads
# AWS_REGION=us-east-1

# Email: SMTP for contact, enterprise, automation (omit = store only, no send)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@crucibai.com
# CONTACT_EMAIL=   # receives contact form
# ENTERPRISE_CONTACT_EMAIL=   # receives enterprise form
