# CrucibAI Backend — copy to `.env` in this folder (`backend/.env`). Never commit `.env`.
# `load_dotenv` loads `backend/.env` automatically when you run uvicorn from `backend/`.

# Local dev: set CRUCIBAI_DEV=1 (also set by ../run-dev.ps1) for relaxed CSRF / rate limits.
# With CRUCIBAI_DEV=1 and no LLM keys below, Workspace returns a small stub app so preview still runs.
# CRUCIBAI_DEV=1 also skips extended Auto-Runner preflight (Node/npm on PATH + health ping) so "Approve & Run" works on Windows when the API process does not see Node.
# Optional: CRUCIBAI_SKIP_AUTORUNNER_PREFLIGHT=1 without CRUCIBAI_DEV (not recommended for production).
# If you run without CRUCIBAI_DEV but Node is not on the API PATH: CRUCIBAI_SKIP_NODE_VERIFY=1 skips `node --check` in verification.compile (run-dev.ps1 sets this).
# Auto-Runner plan checklist is advisory by default. Set CRUCIBAI_STRICT_PLAN_BLOCKERS=1 to allow hard-blocking missing inputs (rare).
#
# Spec Guardian (goal vs runner capability): advisory | strict | off
# - strict (default): blocks run-auto when goal demands Next.js / TS Node API / ORM / schema-per-tenant etc.
# - advisory: records violations + compliance %; run-auto still proceeds
# CRUCIBAI_SPEC_GUARD_MODE=strict
#
# deploy.build: when multitenant RLS migration exists, require backend/*.py to mention set_config + app.tenant_id (set 0 to disable)
# CRUCIBAI_TENANT_CONTEXT_DEPLOY_GATE=1
#
# Optional: live RBAC smoke against running API (anonymous / user token admin denial)
# CRUCIBAI_RBAC_SMOKE_URL=http://127.0.0.1:8000
# CRUCIBAI_RBAC_USER_TOKEN=
#
# verification.security runs tenancy_smoke + stripe_replay + rbac (behavior bundle). In CI (GITHUB_ACTIONS), if
# db/migrations has multitenant RLS, PostgreSQL DATABASE_URL is required for live tenancy proof.
# CRUCIBAI_BEHAVIOR_TENANCY_STRICT=1
#
# After a failed verify_step, executor may run deterministic fix + re-verify (0–5 attempts)
# CRUCIBAI_INNER_VERIFY_REPAIR_MAX=2
#
# If set, git commit inside the job workspace after a deterministic verification repair (workspace must be a git repo)
# CRUCIBAI_VERIFICATION_AUTO_COMMIT=0
#
# JSON request log lines + trace/tenant context (see orchestration/observability.py)
# CRUCIBAI_STRUCTURED_LOGS=0
#
# OpenTelemetry tracer with console span export (optional; adds opentelemetry-* deps)
# CRUCIBAI_OTEL=0
#
# Skip crew-style planning sketches (docs/CREW_*.md, db/migrations/000_crew_schema.sql)
# CRUCIBAI_DISABLE_CREW=0
#
# deploy.build verification: set to 1 to FAIL if workspace code files match leaked-credential patterns
# CRUCIBAI_PRODUCTION_GATE_STRICT=0
#
# Optional: verification.api_smoke performs a live HTTP GET when set (e.g. while API runs on another port)
# CRUCIBAI_API_SMOKE_URL=http://127.0.0.1:8000/health
#
# CI: GitHub Actions sets GITHUB_ACTIONS=true so pytest skips `docker compose` and uses service-container DATABASE_URL.
# Post-deploy probe (repo root): deploy/healthcheck.sh https://your-api.example.com
#
# Optional: verification.security runs `npm audit --omit=dev --json` when npm is on PATH (can be slow)
# CRUCIBAI_NPM_AUDIT_ON_SECURITY=0
# With audit on: fail verification.security when npm audit exits non-zero
# CRUCIBAI_NPM_AUDIT_STRICT=0

# --- Required for full local runs ---
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/crucibai
JWT_SECRET=change-me-to-a-long-random-string

# --- LLM (set at least one) ---
ANTHROPIC_API_KEY=
CEREBRAS_API_KEY=
# Optional pool (round-robin): CEREBRAS_API_KEY_1 … CEREBRAS_API_KEY_5
# CEREBRAS_API_KEY_1=
# CEREBRAS_API_KEY_2=

# Voice / Whisper (Landing, Dashboard, Workspace)
OPENAI_API_KEY=

# Web search
TAVILY_API_KEY=

# --- Local URLs (override any production FRONTEND_URL / API_BASE_URL in your shell) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Workspace API key encryption at rest (Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ---
# CRUCIBAI_ENCRYPTION_KEY=

# --- Queue (optional; omit for in-memory queue) ---
# REDIS_URL=redis://127.0.0.1:6379/0

# --- Pool tuning ---
# DB_POOL_MIN_SIZE=5
# DB_POOL_MAX_SIZE=20
# DB_POOL_TIMEOUT=30

# --- Optional tuning (used where referenced in code / agents) ---
# API_TIMEOUT=120
# BUILD_TIMEOUT_SECONDS=3600
# WORKERS=4
# PARALLEL_WORKERS=4
# MAX_CONCURRENT_AGENTS=50

# Stripe (token purchases)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# S3 / SMTP: see previous sections in your deploy template
