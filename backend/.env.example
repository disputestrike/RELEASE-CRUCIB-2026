# CrucibAI Backend – copy to .env and fill in. Never commit .env or real keys.
# Railway/deploy: set MONGO_URL, DB_NAME, JWT_SECRET (and OPENAI/ANTHROPIC for builds).

# Required: MongoDB (main app DB)
MONGO_URL=mongodb://localhost:27017
DB_NAME=crucibai

# Optional: PostgreSQL (monitoring events, agent cache, future features). When set, db_pg pool and migrations are used.
# DATABASE_URL=postgresql://user:password@localhost:5432/crucibai
DATABASE_URL=

# LLM: set at least one for build/chat (OpenAI and/or Anthropic). Required for build/plan and full test pass.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: legacy / fallback
# LLM_API_KEY=

# Auth (optional; default shown)
# JWT_SECRET=crucibai-secret-key-2024

# CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:3000

# Web search for real-time questions (weather, news, etc.) – get key at https://tavily.com
# TAVILY_API_KEY=

# Images (optional): Together.ai – get key at https://www.together.ai
# TOGETHER_API_KEY=
# TOGETHER_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Videos (optional): Pexels – free key at https://www.pexels.com/api
# PEXELS_API_KEY=

# Branding (free-tier iframe): URL for "Built with CrucibAI" badge. Defaults to BACKEND_PUBLIC_URL + /branding.
# CRUCIBAI_BRANDING_URL=https://api.crucibai.com/branding
# BACKEND_PUBLIC_URL=https://api.crucibai.com

# Stripe (optional, for token purchases)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# FRONTEND_URL=http://localhost:3000
