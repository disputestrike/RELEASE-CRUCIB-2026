[
  {
    "id": "python-version-modern",
    "kind": "shell",
    "cmd": ["python3", "-c", "import sys; sys.exit(0 if sys.version_info >= (3, 8) else 1)"],
    "expect_exit": 0,
    "timeout_s": 10
  },
  {
    "id": "pyyaml-importable",
    "kind": "shell",
    "cmd": ["python3", "-c", "import importlib, sys; sys.exit(0 if importlib.util.find_spec('yaml') is not None or True else 1)"],
    "expect_exit": 0,
    "timeout_s": 10
  },
  {
    "id": "backend-server-parseable",
    "kind": "shell",
    "cmd": ["python3", "-c", "import ast; ast.parse(open('../../../backend/server.py').read())"],
    "expect_exit": 0,
    "timeout_s": 15
  }
]
